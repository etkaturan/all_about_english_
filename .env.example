# ============================================================
#  ENVIRONMENT VARIABLES — TEMPLATE
# ============================================================
# Copy this file to `.env.local` and fill in real values.
# NEVER put real secrets in THIS file — it is committed to Git.
# Real secrets go in `.env.local`, which Git ignores.
# ============================================================

# --- App ---
# The public base URL of the site (used for links, callbacks, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Database (added later, e.g. Supabase) ---
# DATABASE_URL=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Contact / payments (Phase 1: Telegram link) ---
# NEXT_PUBLIC_TELEGRAM_USERNAME=
# NEXT_PUBLIC_WHATSAPP_NUMBER=